<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <title>Lista wydarzeń</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background-color: #2b2b2b;
            color: white;
        }

        .page-title {
            color: white;
        }

        .table {
            background-color: white;
        }

        .table td,
        .table th {
            vertical-align: middle;
        }
    </style>
</head>
<body>

<div class="container mt-5">

    <h1 class="mb-4 page-title">Lista wydarzeń</h1>

    <a href="/events/new" class="btn btn-success mb-3">
        Dodaj wydarzenie
    </a>

    <form action="/events" method="GET" class="mb-3">
        <div class="input-group">
            <input
                type="text"
                name="search"
                class="form-control"
                placeholder="Szukaj wydarzenia..."
                value="<%= search %>"
            >

            <button class="btn btn-success" type="submit">
                Szukaj
            </button>

            <a href="/events" class="btn btn-secondary">
                Wyczyść
            </a>
        </div>
    </form>

    <% if (events.length === 0) { %>

        <div class="alert alert-info">
            Brak wydarzeń.
        </div>

    <% } else { %>

        <table class="table table-striped table-bordered">
            <thead>
                <tr>
                    <th>Nazwa wydarzenia</th>
                    <th>Lokalizacja</th>
                    <th>Pogoda</th>
                    <th>Data</th>
                    <th>Liczba miejsc</th>
                    <th>Akcje</th>
                </tr>
            </thead>

            <tbody>

                <% events.forEach(event => { %>

                    <tr>

                        <td>
                            <%= event.nazwaWydarzenia %>
                        </td>

                        <td>
                            <%= event.lokalizacja %>
                        </td>

                        <td>
                            <%= event.pogoda %>
                        </td>

                        <td>
                            <%= new Date(event.data).toLocaleDateString('pl-PL') %>
                        </td>

                        <td>
                            <%= event.liczbaMiejsc %>
                        </td>

                        <td>

                            <% if (event.liczbaMiejsc > 0) { %>

                                <form
                                    action="/events/<%= event._id %>/reserve"
                                    method="POST"
                                    class="d-inline"
                                >
                                    <button
                                        type="submit"
                                        class="btn btn-success btn-sm"
                                    >
                                        Rezerwuj
                                    </button>
                                </form>

                            <% } else { %>

                                <button
                                    class="btn btn-secondary btn-sm"
                                    disabled
                                >
                                    Brak miejsc
                                </button>

                            <% } %>

                            <form
                                action="/events/<%= event._id %>/edit"
                                method="GET"
                                class="d-inline"
                            >
                                <button
                                    type="submit"
                                    class="btn btn-warning btn-sm"
                                >
                                    Edytuj
                                </button>
                            </form>

                            <form
                                action="/events/<%= event._id %>/delete"
                                method="POST"
                                class="d-inline"
                            >
                                <button
                                    type="submit"
                                    class="btn btn-danger btn-sm"
                                >
                                    Usuń
                                </button>
                            </form>

                        </td>

                    </tr>

                <% }) %>

            </tbody>

        </table>

    <% } %>

</div>

</body>
</html>