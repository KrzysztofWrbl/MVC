<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <title>Dodaj wydarzenie</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #2b2b2b; color: white; }
        .card { background-color: #3a3a3a; color: white; }
        label { margin-bottom: 5px; }
    </style>
</head>
<body>

<div class="container mt-5">
    <div class="card p-4">
        <h1 class="mb-4">Dodaj wydarzenie</h1>

        <form action="/events" method="POST">
            <div class="mb-3">
                <label>Nazwa wydarzenia:</label>
                <input type="text" name="nazwaWydarzenia" class="form-control" required minlength="3">
            </div>

            <div class="mb-3">
                <label>Lokalizacja:</label>
                <input type="text" name="lokalizacja" class="form-control" required minlength="2">
            </div>

            <div class="mb-3">
                <label>Data:</label>
                <input type="date" name="data" class="form-control" required>
            </div>

            <div class="mb-3">
                <label>Liczba miejsc:</label>
                <input type="number" name="liczbaMiejsc" class="form-control" required min="1">
            </div>

            <button type="submit" class="btn btn-success">Dodaj</button>
            <a href="/events" class="btn btn-secondary">Powrót</a>
        </form>
    </div>
</div>

</body>
</html>